datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum TemplateType {
  CLASSIC
  MODERN
  PHOTO
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tokens    verificationToken[]
  resumes   Resume[]
}

model Resume {
  id          String       @id @default(uuid())
  title       String       @default("Untitled Resume")
  template    TemplateType @default(CLASSIC)
  
  // Storing resume structure dynamically as JSON for maximum frontend flexibility
  content     Json         
  
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model verificationToken {
  id        String   @id @default(uuid())
  userId    String?
  email     String?  @unique
  token     String
  expiresAt DateTime
  user      User?    @relation(fields: [userId], references: [id])

  @@map("verification_tokens")
}
